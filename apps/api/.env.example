# Copy this file to apps/api/.env and fill in values.

# Server port (defaults to 4000)
PORT=4000

# CORS allow-list (the frontend origin)
WEB_ORIGIN=http://localhost:5173

# Postgres connection string. Format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://flowfix:flowfix@localhost:5432/flowfix

# Clerk: server-side secret key (starts with sk_test_…)
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk webhook signing secret from the Clerk dashboard (starts with whsec_…)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
